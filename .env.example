# ============================================================================
# KRAKEN TRADING BOT - EXAMPLE CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# --- MODE ---
MODE=sandbox

# --- KRAKEN API ---
KRAKEN_API_BASE=https://api.kraken.com
KRAKEN_API_BASE_URL=https://api.kraken.com
KRAKEN_WS_URL=wss://ws-beta.kraken.com
KRAKEN_API_KEY=your_api_key_here
KRAKEN_API_SECRET=your_api_secret_here

# Nonce settings
KRAKEN_NONCE_MULTIPLIER=1000

# --- PAIRS ---
PAIRS=BTC/USD,ETH/USD,SOL/USD,LINK/USD,AVAX/USD,ADA/USD,LTC/USD,DOT/USD,POL/USD,XRP/USD

# --- NOVA PEAK INDICATOR (Daton's Peak Technology V4.0) ---
NOVA_PEAK_ENABLED=false
NOVA_PEAK_MODE=shadow
NOVA_PEAK_MODEL_PATH=./models/nova_peak_model.pth
NOVA_PEAK_TF=15m
NOVA_PEAK_MIN_PROB=0.80
NOVA_PEAK_MIN_EDGE=0.20
NOVA_LOCK_ON_BUY_PEAK=true
NOVA_TIGHTEN_ON_SELL_PEAK=true
NOVA_TIGHTEN_MULT=0.75
NOVA_COOLDOWN_SECONDS=60

# See full .env for all other settings
